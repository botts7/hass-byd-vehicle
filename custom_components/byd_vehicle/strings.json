{
  "services": {
    "fetch_realtime": {
      "name": "Fetch telemetry data",
      "description": "Force-fetch the latest vehicle telemetry from the BYD cloud.",
      "fields": {
        "device_id": {
          "name": "Device",
          "description": "The BYD vehicle device to fetch data for."
        }
      }
    },
    "fetch_gps": {
      "name": "Fetch GPS data",
      "description": "Force-fetch the latest GPS location from the BYD cloud.",
      "fields": {
        "device_id": {
          "name": "Device",
          "description": "The BYD vehicle device to fetch data for."
        }
      }
    },
    "fetch_hvac": {
      "name": "Fetch HVAC status",
      "description": "Force-fetch the latest HVAC / climate status from the BYD cloud.",
      "fields": {
        "device_id": {
          "name": "Device",
          "description": "The BYD vehicle device to fetch data for."
        }
      }
    },
    "fetch_charging": {
      "name": "Fetch charging status",
      "description": "Force-fetch the latest charging status from the BYD cloud and log the raw response.",
      "fields": {
        "device_id": {
          "name": "Device",
          "description": "The BYD vehicle device to fetch data for."
        }
      }
    },
    "fetch_energy": {
      "name": "Fetch energy consumption",
      "description": "Force-fetch the latest energy consumption data from the BYD cloud and log the raw response.",
      "fields": {
        "device_id": {
          "name": "Device",
          "description": "The BYD vehicle device to fetch data for."
        }
      }
    }
  },
